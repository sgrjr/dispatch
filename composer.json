{
    "name": "sgrjr/dispatch",
    "description": "Drop-in task / bug / feature dispatch pipeline for Laravel: capture from any page (with screenshots), a Kanban board + list for staff, a submitter portal, and a CLI verb-loop that AI agents drive.",
    "keywords": ["laravel", "livewire", "tasks", "issues", "kanban", "dispatch", "bug-tracker"],
    "license": "proprietary",
    "authors": [
        { "name": "Stephen Reynolds" }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/console": "^11.0 || ^12.0",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Sgrjr\\Dispatch\\": "src/",
            "Sgrjr\\Dispatch\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sgrjr\\Dispatch\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sgrjr\\Dispatch\\DispatchServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
